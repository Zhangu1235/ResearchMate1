{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "moduleResolution": "bundler",

    "strict": true,
    "noEmit": true,

    "skipLibCheck": true,
    "isolatedModules": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src"]
}